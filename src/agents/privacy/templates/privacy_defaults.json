  "regex_patterns": {
    "email": {
      "pattern": "\\b[A-Z0-9._%+-]+@[A-Z0-9.-]+\\.[A-Z]{2,}\\b",
      "confidence": 0.92,
      "enabled": true,
      "description": "Email address detection for common RFC-like addresses in free text.",
      "examples": [
        "user@example.com",
        "person.name+tag@sample.org"
      ]
    },
    "phone": {
      "pattern": "(?:(?<!\\w)(?:\\+?\\d{1,3}[\\s.-]?)?(?:\\(?\\d{2,4}\\)?[\\s.-]?)?\\d{3}[\\s.-]?\\d{4}(?!\\w))",
      "confidence": 0.78,
      "enabled": true,
      "description": "Flexible phone detection across international and formatted local variants.",
      "examples": [
        "+1 202-555-0188",
        "+31 6 12345678"
      ]
    },
    "ssn": {
      "pattern": "\\b\\d{3}-\\d{2}-\\d{4}\\b",
      "confidence": 0.97,
      "enabled": true,
      "description": "US SSN formatted identifier detection.",
      "examples": [
        "123-45-6789"
      ]
    },
    "credit_card": {
      "pattern": "\\b(?:\\d[ -]*?){13,19}\\b",
      "confidence": 0.86,
      "enabled": true,
      "description": "Payment card candidate detection before downstream length and heuristic validation.",
      "examples": [
        "4111 1111 1111 1111"
      ]
    },
    "ipv4": {
      "pattern": "\\b(?:\\d{1,3}\\.){3}\\d{1,3}\\b",
      "confidence": 0.8,
      "enabled": true,
      "description": "IPv4 address detection for network metadata classification.",
      "examples": [
        "192.168.10.25"
      ]
    },
    "passport": {
      "pattern": "\\b[A-Z]{1,2}\\d{6,9}\\b",
      "confidence": 0.82,
      "enabled": true,
      "description": "Generic passport-like alphanumeric identifier detection.",
      "examples": [
        "P12345678",
        "AB1234567"
      ]
    },
    "national_id": {
      "pattern": "\\b\\d{8,16}\\b",
      "confidence": 0.7,
      "enabled": true,
      "description": "Broad national identifier candidate detection gated by contextual field heuristics.",
      "examples": [
        "123456789012"
      ]
    },
    "date_of_birth": {
      "pattern": "\\b(?:19|20)\\d{2}[-/]\\d{2}[-/]\\d{2}\\b",
      "confidence": 0.82,
      "enabled": true,
      "description": "Date-like value detection limited to common full-year formats.",
      "examples": [
        "1992-07-14",
        "2001/01/01"
      ]
    }
  },
