  "heuristics": {
    "field_skip_rules": [
      {
        "entity_type": "address",
        "skip_if_tokens_present": [
          "ip"
        ],
        "reason": "Avoid classifying ip_address or similar network fields as postal addresses."
      },
      {
        "entity_type": "phone",
        "skip_if_tokens_present": [
          "account",
          "id"
        ],
        "skip_unless_any_tokens_present": [
          "phone",
          "mobile"
        ],
        "reason": "Avoid over-classifying account identifiers as phone values."
      },
      {
        "entity_type": "email",
        "skip_if_tokens_present": [
          "filename"
        ],
        "reason": "Avoid classifying filename fields with extensions as email indicators."
      }
    ],
    "regex_skip_rules": [
      {
        "entity_type": "address",
        "skip_if_tokens_present": [
          "ip"
        ],
        "reason": "Avoid postal-address detection in IP fields."
      },
      {
        "entity_type": "phone",
        "skip_if_tokens_present": [
          "account",
          "id"
        ],
        "skip_unless_any_tokens_present": [
          "phone",
          "mobile"
        ],
        "reason": "Avoid numeric account values matching broad phone regex patterns."
      },
      {
        "entity_type": "national_id",
        "require_any_tokens": [
          "id",
          "national",
          "government",
          "tax",
          "passport",
          "ssn"
        ],
        "reason": "Avoid treating arbitrary numeric strings as regulated identifiers without context."
      },
      {
        "entity_type": "credit_card",
        "minimum_digits": 13,
        "reason": "Require a realistic payment-card digit count before classification."
      }
    ]
  },
