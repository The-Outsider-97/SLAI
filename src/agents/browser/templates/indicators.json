{
  "template_name": "browser_security_indicators",
  "description": "Protective detection indicators for the browser agent security layer. These indicators identify states where the agent should warn, pause, block, or request human oversight. They are not bypass instructions.",
  "project_path": "scr/agents/browser/templates/indicators.json",
  "last_reviewed": "2026-04-25",
  "owner": "browser.security",
  "defaults": {
    "enabled": true,
    "case_sensitive": false,
    "normalize_whitespace": true,
    "strip_zero_width_chars": true,
    "unicode_normalization": "NFKC",
    "max_text_scan_chars": 250000,
    "max_evidence_chars": 500,
    "match_policy": "any",
    "evidence_policy": "bounded_redacted_snippets",
    "decision_hints": {
      "allow": "Continue without interrupting the workflow.",
      "warn": "Continue only if the caller or policy allows risk-tolerant execution.",
      "block": "Stop automated action and require explicit human review or an alternate safe path."
    }
  },
  "severity_scale": {
    "info": {
      "risk_score": 0.05,
      "description": "Low-risk signal useful for context."
    },
    "low": {
      "risk_score": 0.15,
      "description": "Minor risk or weak signal; usually warn only when combined."
    },
    "medium": {
      "risk_score": 0.35,
      "description": "Meaningful risk or protected interaction; usually warn."
    },
    "high": {
      "risk_score": 0.7,
      "description": "Strong protective signal; often block depending on policy."
    },
    "critical": {
      "risk_score": 0.95,
      "description": "Sensitive or unsafe state; block by default."
    }
  },
  "categories": {
    "captcha": {
      "enabled": true,
      "description": "Human-verification and CAPTCHA challenges. The agent should stop or request human oversight rather than trying to bypass the challenge.",
      "decision": "block",
      "severity": "high",
      "risk_score": 0.82,
      "match_policy": "any",
      "evidence_types": [
        "text",
        "dom",
        "url"
      ],
      "matchers": {
        "text": [
          "are you a robot",
          "automated queries",
          "automated traffic",
          "browser verification",
          "captcha",
          "CAPTCHA",
          "challenge page",
          "checking if the site connection is secure",
          "checking your browser",
          "Cloudflare Turnstile",
          "complete the CAPTCHA",
          "complete the security check",
          "complete this challenge",
          "confirm you are not a robot",
          "drag the puzzle piece",
          "enter the code shown",
          "hCaptcha",
          "human verification",
          "I am not a robot",
          "I'm not a robot",
          "managed challenge",
          "please verify",
          "press and hold",
          "prove you are human",
          "prove you're human",
          "reCAPTCHA",
          "review the security of your connection",
          "robot check",
          "security check",
          "select all images",
          "solve the captcha",
          "turnstile",
          "type the characters you see",
          "unusual traffic",
          "verification required",
          "verify that you are human",
          "verify you are human",
          "verify you're human"
        ],
        "css_selectors": [
          "#challenge-form",
          ".cf-challenge",
          ".cf-turnstile",
          ".g-recaptcha",
          ".h-captcha",
          "[aria-label*='captcha' i]",
          "[class*='captcha' i]",
          "[data-hcaptcha-widget-id]",
          "[data-sitekey]",
          "[data-testid*='captcha' i]",
          "[id*='captcha' i]",
          "form[action*='captcha' i]",
          "iframe[src*='challenges.cloudflare.com']",
          "iframe[src*='google.com/recaptcha']",
          "iframe[src*='hcaptcha']",
          "iframe[src*='recaptcha']",
          "iframe[title*='captcha' i]",
          "iframe[title*='recaptcha' i]",
          "input[name='cf-turnstile-response']",
          "textarea[name='g-recaptcha-response']",
          "textarea[name='h-captcha-response']"
        ],
        "url_contains": [
          "/captcha",
          "challenge-platform",
          "challenges.cloudflare.com",
          "hcaptcha",
          "recaptcha",
          "turnstile"
        ]
      },
      "false_positive_hints": [],
      "notes": [
        "Detection is protective only; do not automate challenge solving or evasion."
      ]
    },
    "bot_detection_block": {
      "enabled": true,
      "description": "Bot-detection, anti-automation, WAF, and automated-access blocks.",
      "decision": "block",
      "severity": "high",
      "risk_score": 0.78,
      "match_policy": "any",
      "evidence_types": [
        "text",
        "dom",
        "url",
        "headers",
        "status_code"
      ],
      "matchers": {
        "text": [
          "403 forbidden",
          "access denied",
          "Akamai Bot Manager",
          "anti-bot",
          "automated access",
          "automated browser",
          "automated browsing",
          "automated traffic",
          "blocked by security rules",
          "blocked due to suspicious activity",
          "bot detection",
          "bot protection",
          "bot score",
          "browser not supported",
          "Cloudflare Ray ID",
          "DataDome",
          "forbidden",
          "headless browser detected",
          "Imperva",
          "Incapsula",
          "Kasada",
          "malformed request",
          "not allowed to access this page",
          "PerimeterX",
          "please enable cookies",
          "please enable JavaScript",
          "Ray ID",
          "request blocked",
          "request rejected",
          "security policy blocked",
          "suspicious activity detected",
          "temporarily blocked",
          "traffic from your network",
          "unusual activity from your network",
          "WAF",
          "we have detected unusual behavior",
          "we've detected unusual behavior",
          "web application firewall",
          "your request has been blocked"
        ],
        "css_selectors": [
          "#px-captcha",
          "[class*='challenge' i]",
          "[class*='datadome' i]",
          "[class*='perimeterx' i]",
          "[id*='challenge' i]",
          "[id*='datadome' i]",
          "[id*='perimeterx' i]",
          "script[src*='akamai']",
          "script[src*='datadome']",
          "script[src*='kasada']",
          "script[src*='perimeterx']"
        ],
        "url_contains": [
          "akamai",
          "bot-manager",
          "challenge",
          "datadome",
          "incapsula",
          "kasada",
          "perimeterx"
        ],
        "headers": {
          "server_contains": [
            "cloudflare",
            "akamai",
            "imperva",
            "incapsula"
          ],
          "set_cookie_contains": [
            "ak_bmsc",
            "bm_sv",
            "bm_sz",
            "_px",
            "datadome",
            "visid_incap",
            "incap_ses"
          ]
        },
        "status_codes": [
          401,
          403,
          406,
          409,
          418,
          429,
          451,
          503
        ]
      },
      "false_positive_hints": [],
      "notes": [
        "Treat as a site-protection signal, not as a prompt to evade controls."
      ]
    },
    "rate_limit": {
      "enabled": true,
      "description": "Rate-limiting and quota exhaustion signals. The agent should back off and avoid repeated requests.",
      "decision": "warn",
      "severity": "medium",
      "risk_score": 0.5,
      "match_policy": "any",
      "evidence_types": [
        "text",
        "headers",
        "status_code"
      ],
      "matchers": {
        "text": [
          "429",
          "back off",
          "exceeded allowed request rate",
          "HTTP 429",
          "maximum requests",
          "over capacity",
          "please try again later",
          "quota exceeded",
          "rate limit",
          "rate limited",
          "request limit reached",
          "request quota exceeded",
          "retry after",
          "server busy",
          "service unavailable",
          "slow down",
          "temporarily rate limited",
          "temporarily unavailable",
          "throttled",
          "too many requests",
          "try again later",
          "usage limit exceeded",
          "you are being throttled"
        ],
        "headers": {
          "names": [
            "retry-after",
            "x-ratelimit-limit",
            "x-ratelimit-remaining",
            "x-ratelimit-reset",
            "ratelimit-limit",
            "ratelimit-remaining",
            "ratelimit-reset"
          ]
        },
        "status_codes": [
          429,
          503
        ]
      },
      "false_positive_hints": [],
      "notes": [
        "Use configured backoff rather than repeated immediate retries."
      ]
    },
    "login_auth_wall": {
      "enabled": true,
      "description": "Login, authentication, SSO, MFA, session-expiry, or account-wall states.",
      "decision": "warn",
      "severity": "medium",
      "risk_score": 0.42,
      "match_policy": "any",
      "evidence_types": [
        "text",
        "dom",
        "url",
        "status_code"
      ],
      "matchers": {
        "text": [
          "2FA",
          "account required",
          "authentication required",
          "authorization required",
          "check your email",
          "continue with Google",
          "continue with Microsoft",
          "create an account to continue",
          "enter your code",
          "log in required",
          "log in to continue",
          "login required",
          "membership required",
          "MFA",
          "multi-factor authentication",
          "not authenticated",
          "organization access required",
          "password required",
          "please log in",
          "please sign in",
          "private workspace",
          "session expired",
          "sign in to continue",
          "single sign-on",
          "SSO required",
          "subscribe to continue",
          "two-factor authentication",
          "verification code",
          "verify your email",
          "verify your identity",
          "your session has expired"
        ],
        "css_selectors": [
          "[data-testid*='login' i]",
          "[data-testid*='signin' i]",
          "a[href*='login' i]",
          "a[href*='signin' i]",
          "form[action*='login' i]",
          "form[action*='signin' i]",
          "input[autocomplete='one-time-code']",
          "input[name*='password' i]",
          "input[type='password']"
        ],
        "url_contains": [
          "/account",
          "/auth",
          "/login",
          "/mfa",
          "/oauth",
          "/session",
          "/sign-in",
          "/signin",
          "/sso"
        ],
        "status_codes": [
          401,
          403
        ]
      },
      "false_positive_hints": [],
      "notes": [
        "Warn because credentials or user-specific authorization may be required."
      ]
    },
    "permission_access_denied": {
      "enabled": true,
      "description": "Permission-denied and authorization failure states that may indicate private or restricted content.",
      "decision": "warn",
      "severity": "medium",
      "risk_score": 0.45,
      "match_policy": "any",
      "evidence_types": [
        "text",
        "status_code"
      ],
      "matchers": {
        "text": [
          "401 unauthorized",
          "403 forbidden",
          "access forbidden",
          "access restricted",
          "administrator approval required",
          "contact your administrator",
          "insufficient permissions",
          "not authorized",
          "organization restricted",
          "permission denied",
          "private document",
          "private page",
          "private repository",
          "request access",
          "unauthorized",
          "workspace restricted",
          "you do not have access",
          "you don't have access"
        ],
        "status_codes": [
          401,
          403,
          451
        ]
      },
      "false_positive_hints": [],
      "notes": [
        "Do not attempt to bypass access controls; surface the state to the caller."
      ]
    },
    "unsafe_url_scheme": {
      "enabled": true,
      "description": "URL schemes that should not be navigated by an automated browser agent unless explicitly allowed by policy.",
      "decision": "block",
      "severity": "high",
      "risk_score": 0.8,
      "match_policy": "any",
      "evidence_types": [
        "scheme"
      ],
      "matchers": {
        "schemes": [
          "about",
          "blob",
          "chrome",
          "chrome-extension",
          "data",
          "edge",
          "file",
          "ftp",
          "intent",
          "javascript",
          "ms-appx",
          "ms-appx-web",
          "powershell",
          "shell",
          "vbscript",
          "view-source"
        ]
      },
      "false_positive_hints": [],
      "notes": [
        "http and https are the default allowed navigation schemes."
      ]
    },
    "private_network_or_local_target": {
      "enabled": true,
      "description": "Localhost, private-network, loopback, link-local, and cloud-metadata targets that can expose internal services or credentials.",
      "decision": "block",
      "severity": "critical",
      "risk_score": 0.92,
      "match_policy": "any",
      "evidence_types": [
        "text",
        "regex",
        "domain"
      ],
      "matchers": {
        "text": [
          "0.0.0.0",
          "100.100.100.200",
          "127.0.0.1",
          "169.254.169.254",
          "::1",
          "localhost",
          "metadata.google.internal"
        ],
        "regex": [
          "(?i)^https?://100\\.100\\.100\\.200(?::|/|$)",
          "(?i)^https?://10\\.\\d+\\.\\d+\\.\\d+(?::|/|$)",
          "(?i)^https?://127\\.\\d+\\.\\d+\\.\\d+(?::|/|$)",
          "(?i)^https?://169\\.254\\.169\\.254(?::|/|$)",
          "(?i)^https?://169\\.254\\.\\d+\\.\\d+(?::|/|$)",
          "(?i)^https?://172\\.(1[6-9]|2\\d|3[0-1])\\.\\d+\\.\\d+(?::|/|$)",
          "(?i)^https?://192\\.168\\.\\d+\\.\\d+(?::|/|$)",
          "(?i)^https?://\\[?::1\\]?(?::|/|$)",
          "(?i)^https?://localhost(?::|/|$)",
          "(?i)^https?://metadata\\.google\\.internal(?::|/|$)"
        ],
        "domains": [
          "ip6-localhost",
          "ip6-loopback",
          "localhost",
          "metadata.google.internal"
        ]
      },
      "false_positive_hints": [],
      "notes": [
        "Protects against SSRF-style browsing and accidental access to local/internal services."
      ]
    },
    "dangerous_download_or_execution": {
      "enabled": true,
      "description": "Executable, script, installer, or package downloads that may execute code or alter the host system.",
      "decision": "warn",
      "severity": "high",
      "risk_score": 0.68,
      "match_policy": "any",
      "evidence_types": [
        "text",
        "download",
        "mime_type"
