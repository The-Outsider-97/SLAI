    "credential_or_secret_exposure": {
      "enabled": true,
      "description": "Credentials, API keys, access tokens, private keys, session cookies, and other secrets in page content, URLs, forms, or action payloads.",
      "decision": "block",
      "severity": "critical",
      "risk_score": 0.96,
      "match_policy": "any",
      "evidence_types": [
        "text",
        "regex",
        "attribute"
      ],
      "matchers": {
        "text": [
          "access token",
          "api key",
          "authorization bearer",
          "BEGIN EC PRIVATE KEY",
          "BEGIN OPENSSH PRIVATE KEY",
          "BEGIN PRIVATE KEY",
          "BEGIN RSA PRIVATE KEY",
          "client secret",
          "credential",
          "passwd",
          "password",
          "private key",
          "refresh token",
          "secret key",
          "service account",
          "session cookie",
          "ssh private key"
        ],
        "regex": [
          "(?i)access[_-]?token\\s*[:=]\\s*['\\\"]?[A-Za-z0-9_\\-.]{16,}",
          "(?i)api[_-]?key\\s*[:=]\\s*['\\\"]?[A-Za-z0-9_\\-.]{16,}",
          "(?i)authorization\\s*[:=]\\s*bearer\\s+[A-Za-z0-9_\\-.]{16,}",
          "(?i)client[_-]?secret\\s*[:=]\\s*['\\\"]?[A-Za-z0-9_\\-.]{16,}",
          "(?i)cookie\\s*[:=]\\s*[^;\\n]{16,}",
          "(?i)password\\s*[:=]\\s*\\S{6,}",
          "(?i)refresh[_-]?token\\s*[:=]\\s*['\\\"]?[A-Za-z0-9_\\-.]{16,}",
          "(?i)secret\\s*[:=]\\s*['\\\"]?[A-Za-z0-9_\\-.]{16,}",
          "(?i)session(id)?\\s*[:=]\\s*[A-Za-z0-9_\\-.]{16,}",
          "-----BEGIN (RSA |DSA |EC |OPENSSH |PGP )?PRIVATE KEY-----",
          "AIza[0-9A-Za-z_\\-]{35}",
          "AKIA[0-9A-Z]{16}",
          "ASIA[0-9A-Z]{16}",
          "eyJ[A-Za-z0-9_\\-]+\\.[A-Za-z0-9_\\-]+\\.[A-Za-z0-9_\\-]+",
          "gh[pousr]_[A-Za-z0-9_]{30,}",
          "github_pat_[A-Za-z0-9_]{20,}",
          "rk_live_[A-Za-z0-9]{20,}",
          "sk-[A-Za-z0-9]{20,}",
          "sk-live-[A-Za-z0-9]{20,}",
          "xox[baprs]-[A-Za-z0-9-]{20,}"
        ],
        "attributes": {
          "sensitive_names": [
            "password",
            "passwd",
            "token",
            "access_token",
            "refresh_token",
            "api_key",
            "apikey",
            "secret",
            "client_secret",
            "authorization",
            "cookie",
            "session",
            "csrf",
            "xsrf"
          ]
        }
      },
      "false_positive_hints": [],
      "notes": [
        "Evidence should be redacted by default. Prefer detection metadata over raw secret values."
      ]
    },
    "payment_financial_data": {
      "enabled": true,
      "description": "Payment-card, bank-account, tax, or financial identifiers that should not be logged or replayed.",
      "decision": "warn",
      "severity": "high",
      "risk_score": 0.7,
      "match_policy": "any",
      "evidence_types": [
        "text",
        "regex"
      ],
      "matchers": {
        "text": [
          "bank account",
          "billing address",
          "card number",
          "credit card",
          "CVC",
          "CVV",
          "expiration date",
          "IBAN",
          "invoice payment",
          "routing number",
          "security code",
          "SWIFT",
          "tax id",
          "VAT number",
          "wire transfer"
        ],
        "regex": [
          "(?<!\\d)(?:4\\d{3}|5[1-5]\\d{2}|3[47]\\d{2}|6(?:011|5\\d{2}))[- ]?\\d{4}[- ]?\\d{4}[- ]?\\d{3,4}(?!\\d)",
          "(?i)cvc\\s*[:=]?\\s*\\d{3,4}",
          "(?i)cvv\\s*[:=]?\\s*\\d{3,4}",
          "(?i)iban\\s*[:=]?\\s*[A-Z]{2}\\d{2}[A-Z0-9]{10,30}",
          "(?i)swift\\s*[:=]?\\s*[A-Z]{6}[A-Z0-9]{2}([A-Z0-9]{3})?"
        ]
      },
      "false_positive_hints": [],
      "notes": [
        "Do not store raw financial identifiers in memory, logs, or test fixtures."
      ]
    },
    "personal_data_pii": {
      "enabled": true,
      "description": "Personal data and identity information that may require privacy-preserving handling.",
      "decision": "warn",
      "severity": "medium",
      "risk_score": 0.38,
      "match_policy": "any",
      "evidence_types": [
        "text",
        "regex"
      ],
      "matchers": {
        "text": [
          "date of birth",
          "driver license",
          "email address",
          "home address",
          "medical record",
          "national insurance number",
          "passport number",
          "patient id",
          "personal address",
          "phone number",
          "resident registration number",
          "social security number",
          "SSN"
        ],
        "regex": [
          "(?<!\\d)(?:\\+?\\d{1,3}[ .-]?)?(?:\\(?\\d{2,4}\\)?[ .-]?)?\\d{3,4}[ .-]?\\d{4}(?!\\d)",
          "(?<!\\d)\\d{3}-\\d{2}-\\d{4}(?!\\d)",
          "(?i)(date of birth|dob)\\s*[:=]?\\s*\\d{1,2}[/-]\\d{1,2}[/-]\\d{2,4}",
          "(?i)passport\\s*(number|no\\.)?\\s*[:=]?\\s*[A-Z0-9]{6,12}",
          "(?i)ssn\\s*[:=]?\\s*\\d{3}-\\d{2}-\\d{4}",
          "[A-Za-z0-9._%+-]+@[A-Za-z0-9.-]+\\.[A-Za-z]{2,}"
        ]
      },
      "false_positive_hints": [],
      "notes": [
        "PII detection can be noisy; treat as warning unless policy requires blocking."
      ]
    },
